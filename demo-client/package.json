    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.428.0",
    "mermaid": "^10.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "socket.io-client": "^4.7.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-react": "^1.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
